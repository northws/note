<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HandwrittenNotes.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="AppAccentColor">#6C63FF</Color>
            <Color x:Key="AppAccentLightColor">#8B85FF</Color>
            <Color x:Key="SidebarBackground">#1E1E2E</Color>
            <Color x:Key="SidebarForeground">#CDD6F4</Color>
            <Color x:Key="ToolbarBackground">#181825</Color>
            <Color x:Key="CanvasBackground">#FFFFFF</Color>

            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppAccentLightBrush" Color="{StaticResource AppAccentLightColor}" />
            <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}" />
            <SolidColorBrush x:Key="SidebarForegroundBrush" Color="{StaticResource SidebarForeground}" />
            <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource ToolbarBackground}" />
            <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="{StaticResource CanvasBackground}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
