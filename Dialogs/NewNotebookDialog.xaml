<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="HandwrittenNotes.Dialogs.NewNotebookDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="新建笔记"
    PrimaryButtonText="创建"
    CloseButtonText="取消"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="300">
        <TextBox
            x:Name="NotebookNameTextBox"
            Header="笔记名称"
            PlaceholderText="输入笔记名称"
            Text="未命名笔记" />

        <ComboBox
            x:Name="PageSizeComboBox"
            Header="页面大小"
            HorizontalAlignment="Stretch"
            SelectedIndex="0">
            <x:String>A4</x:String>
            <x:String>A3</x:String>
            <x:String>Letter</x:String>
        </ComboBox>

        <ComboBox
            x:Name="BackgroundTypeComboBox"
            Header="背景样式"
            HorizontalAlignment="Stretch"
            SelectedIndex="0">
            <x:String>网格</x:String>
            <x:String>空白</x:String>
            <x:String>横线</x:String>
            <x:String>点阵</x:String>
        </ComboBox>

        <ComboBox
            x:Name="TemplateComboBox"
            Header="模板"
            HorizontalAlignment="Stretch"
            SelectedIndex="0">
            <x:String>自定义（无模板）</x:String>
            <x:String>康奈尔笔记</x:String>
            <x:String>会议记录</x:String>
            <x:String>四象限待办</x:String>
        </ComboBox>
    </StackPanel>
</ContentDialog>
