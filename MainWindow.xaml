<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HandwrittenNotes.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HandwrittenNotes.Controls"
    xmlns:models="using:HandwrittenNotes.Models"
    Title="手写笔记">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#1E1E2E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="12" Spacing="8">
                <TextBlock Text="手写笔记" FontSize="20" Foreground="#CDD6F4" />
                <TextBlock
                    x:Name="NotebookCountText"
                    Text="0 本笔记"
                    Foreground="#CDD6F4"
                    FontSize="12" />
            </StackPanel>

            <Button
                Grid.Row="1"
                x:Name="NewNotebookButton"
                Click="NewNotebookButton_Click"
                Content="新建笔记"
                Margin="12,0,12,8" />

            <TextBox
                Grid.Row="2"
                x:Name="NotebookSearchBox"
                TextChanged="NotebookSearchBox_TextChanged"
                PlaceholderText="搜索笔记名称..."
                Margin="12,0,12,8" />

            <Grid Grid.Row="3" Margin="8,0,8,8">
                <ListView
                    x:Name="NotebookListView"
                    SelectionChanged="NotebookListView_SelectionChanged"
                    Background="Transparent"
                    BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="{Binding Name}"
                                    Foreground="#CDD6F4"
                                    VerticalAlignment="Center"
                                    TextTrimming="CharacterEllipsis" />
                                <Button
                                    Grid.Column="1"
                                    Tag="{Binding Id}"
                                    Click="DeleteNotebook_Click"
                                    Content="删"
                                    Padding="8,2" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    x:Name="NotebookEmptyState"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="4"
                    IsHitTestVisible="False">
                    <TextBlock
                        x:Name="NotebookEmptyTitleText"
                        Text="还没有笔记"
                        Foreground="#CDD6F4"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="NotebookEmptyDescriptionText"
                        Text="点击上方按钮创建第一本笔记"
                        Foreground="#99CDD6F4"
                        FontSize="12" />
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Column="1" Background="#313244" />

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <controls:InkToolbar
                Grid.Row="0"
                x:Name="ToolBar"
                ToolChanged="ToolBar_ToolChanged"
                ColorChanged="ToolBar_ColorChanged"
                StrokeWidthChanged="ToolBar_StrokeWidthChanged"
                UndoRequested="ToolBar_UndoRequested"
                RedoRequested="ToolBar_RedoRequested"
                ClearRequested="ToolBar_ClearRequested"
                ExportPdfRequested="ToolBar_ExportPdfRequested"
                ImportPdfRequested="ToolBar_ImportPdfRequested"
                InsertImageRequested="ToolBar_InsertImageRequested"
                ZoomInRequested="ToolBar_ZoomInRequested"
                ZoomOutRequested="ToolBar_ZoomOutRequested"
                ZoomResetRequested="ToolBar_ZoomResetRequested"
                Margin="12,12,12,8" />

            <Grid Grid.Row="1" Margin="12,0,12,12">
                <controls:InkCanvas
                    x:Name="DrawingCanvas"
                    StrokesChanged="DrawingCanvas_StrokesChanged" />

                <Border
                    x:Name="WelcomePanel"
                    Background="#F7F8FC"
                    Visibility="Visible">
                    <TextBlock
                        Text="欢迎使用手写笔记"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="24" />
                </Border>
            </Grid>

            <StackPanel
                Grid.Row="2"
                x:Name="PageNavBar"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Spacing="8"
                Margin="12,0,12,12"
                Visibility="Collapsed">
                <Button
                    x:Name="PrevPageButton"
                    Click="PrevPageButton_Click"
                    Content="上一页" />
                <TextBlock
                    x:Name="PageInfoText"
                    Text="第 1 / 1 页"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="NextPageButton"
                    Click="NextPageButton_Click"
                    Content="下一页" />
                <Button
                    x:Name="AddPageButton"
                    Click="AddPageButton_Click"
                    Content="添加页面" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
