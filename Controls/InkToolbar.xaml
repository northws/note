<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HandwrittenNotes.Controls.InkToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        Background="{StaticResource ToolbarBackgroundBrush}"
        Padding="8,4"
        CornerRadius="0">
        <StackPanel Orientation="Horizontal" Spacing="4">

            <!-- 笔工具 -->
            <ToggleButton
                x:Name="PenButton"
                IsChecked="True"
                Click="PenButton_Click"
                ToolTipService.ToolTip="钢笔"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xEE56;" FontSize="18" />
            </ToggleButton>

            <ToggleButton
                x:Name="HighlighterButton"
                Click="HighlighterButton_Click"
                ToolTipService.ToolTip="荧光笔"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE7E6;" FontSize="18" />
            </ToggleButton>

            <ToggleButton
                x:Name="EraserButton"
                Click="EraserButton_Click"
                ToolTipService.ToolTip="橡皮擦"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE75C;" FontSize="18" />
            </ToggleButton>

            <AppBarSeparator />

            <!-- 颜色选择 -->
            <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                <Button x:Name="ColorBlack" Click="Color_Click" Tag="#1E1E2E"
                        Width="28" Height="28" Padding="0" CornerRadius="14"
                        ToolTipService.ToolTip="黑色"
                        BorderThickness="2" BorderBrush="Gray">
                    <Ellipse Width="18" Height="18" Fill="#1E1E2E" />
                </Button>
                <Button x:Name="ColorRed" Click="Color_Click" Tag="#E64553"
                        Width="28" Height="28" Padding="0" CornerRadius="14"
                        ToolTipService.ToolTip="红色">
                    <Ellipse Width="18" Height="18" Fill="#E64553" />
                </Button>
                <Button x:Name="ColorBlue" Click="Color_Click" Tag="#1E66F5"
                        Width="28" Height="28" Padding="0" CornerRadius="14"
                        ToolTipService.ToolTip="蓝色">
                    <Ellipse Width="18" Height="18" Fill="#1E66F5" />
                </Button>
                <Button x:Name="ColorGreen" Click="Color_Click" Tag="#40A02B"
                        Width="28" Height="28" Padding="0" CornerRadius="14"
                        ToolTipService.ToolTip="绿色">
                    <Ellipse Width="18" Height="18" Fill="#40A02B" />
                </Button>
                <Button x:Name="ColorOrange" Click="Color_Click" Tag="#FE640B"
                        Width="28" Height="28" Padding="0" CornerRadius="14"
                        ToolTipService.ToolTip="橙色">
                    <Ellipse Width="18" Height="18" Fill="#FE640B" />
                </Button>
                <Button x:Name="ColorPurple" Click="Color_Click" Tag="#8839EF"
                        Width="28" Height="28" Padding="0" CornerRadius="14"
                        ToolTipService.ToolTip="紫色">
                    <Ellipse Width="18" Height="18" Fill="#8839EF" />
                </Button>
            </StackPanel>

            <AppBarSeparator />

            <!-- 笔画粗细 -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <FontIcon Glyph="&#xEDA7;" FontSize="14" Foreground="{StaticResource SidebarForegroundBrush}" />
                <Slider
                    x:Name="StrokeWidthSlider"
                    Minimum="0.5" Maximum="12" Value="2.5"
                    StepFrequency="0.5"
                    Width="120"
                    ValueChanged="StrokeWidthSlider_ValueChanged"
                    ToolTipService.ToolTip="笔画粗细" />
                <TextBlock
                    x:Name="StrokeWidthText"
                    Text="2.5"
                    Foreground="{StaticResource SidebarForegroundBrush}"
                    VerticalAlignment="Center"
                    FontSize="12"
                    Width="30" />
            </StackPanel>

            <AppBarSeparator />

            <!-- 撤销/重做 -->
            <Button
                x:Name="UndoButton"
                Click="UndoButton_Click"
                ToolTipService.ToolTip="撤销 (Ctrl+Z)"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE7A7;" FontSize="16" />
            </Button>
            <Button
                x:Name="RedoButton"
                Click="RedoButton_Click"
                ToolTipService.ToolTip="重做 (Ctrl+Y)"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE7A6;" FontSize="16" />
            </Button>

            <AppBarSeparator />

<!-- 清除 -->
            <Button
                x:Name="ClearButton"
                Click="ClearButton_Click"
                ToolTipService.ToolTip="清除所有"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE74D;" FontSize="16" />
            </Button>

            <AppBarSeparator />

            <!-- 导出PDF -->
            <Button
                x:Name="ExportPdfButton"
                Click="ExportPdfButton_Click"
                ToolTipService.ToolTip="导出为PDF"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE8E5;" FontSize="16" />
            </Button>

            <!-- 导入PDF -->
            <Button
                x:Name="ImportPdfButton"
                Click="ImportPdfButton_Click"
                ToolTipService.ToolTip="导入PDF"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE8A5;" FontSize="16" />
            </Button>

            <AppBarSeparator />

            <!-- 缩放 -->
            <Button
                x:Name="ZoomOutButton"
                Click="ZoomOutButton_Click"
                ToolTipService.ToolTip="缩小 (Ctrl+-)"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE71F;" FontSize="16" />
            </Button>
            <TextBlock
                x:Name="ZoomLevelText"
                Text="100%"
                Foreground="{StaticResource SidebarForegroundBrush}"
                VerticalAlignment="Center"
                FontSize="12"
                Width="45"
                TextAlignment="Center" />
            <Button
                x:Name="ZoomInButton"
                Click="ZoomInButton_Click"
                ToolTipService.ToolTip="放大 (Ctrl++)"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE8A3;" FontSize="16" />
            </Button>
            <Button
                x:Name="ZoomResetButton"
                Click="ZoomResetButton_Click"
                ToolTipService.ToolTip="重置缩放"
                Width="40" Height="40"
                Padding="0">
                <FontIcon Glyph="&#xE71D;" FontSize="16" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
